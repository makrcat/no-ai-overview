{
  "name": "No AI Overview",
  "description": "Prevents google searches from prompting AI overview, through configureable methods.",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": ["declarativeNetRequest", "storage"],
  "host_permissions": ["*://*.google.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {"id": "ruleset_flag","enabled": true, "path": "flag.json"},
      {"id": "ruleset_udm", "enabled":true, "path":"udm.json"}
    ]
  },
  "action": {
    "default_icon": "icon1.png",
    "default_popup": "index.html"
  }
}